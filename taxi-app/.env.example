PORT=3000

# Get this from:
#  Supabase → Project Settings → Database → Connection string (URI mode)
#  Neon     → Dashboard → Connection Details → Connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
