{
  "name": "AI Executive Action Flow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ai-action",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "ai-action-webhook-id"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT full_name, phone, loyalty_points, loyalty_tier FROM customers WHERE loyalty_tier = 'بلاتيني' LIMIT 5;"
      },
      "id": "2",
      "name": "Get VIP Customers",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.2,
      "position": [450, 300],
      "credentials": {
        "postgres": {
          "id": "postgres-cred-id",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "send",
        "fromEmail": "rafiq-assistant@rafiq.dz",
        "toEmail": "mock-vip-customer@rafiq.dz",
        "subject": "="هدية ولاء من منصة الرفيق سيدي {{ $json.full_name }}",
        "html": "=<div dir='rtl'><h3>مرحباً {{ $json.full_name }}</h3><p>بناءً على تعليمات المدير التنفيذي، نهديك قسيمة خصم VIP بقيمة 20% تقديراً لولائك (المستوى البلاتيني - {{ $json.loyalty_points }} نقطة).</p></div>"
      },
      "id": "3",
      "name": "Send VIP Discount Emails",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [650, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://backend:8000/api/alerts",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "title_ar", "value": "🤖 المساعد الذكي: تم التنفيذ" },
            { "name": "body_ar", "value": "تم إرسال قسائم الخصم إلى العملاء البلاتينيين بنجاح." },
            { "name": "severity", "value": "info" },
            { "name": "type", "value": "ai_action_completed" }
          ]
        },
        "options": {}
      },
      "id": "4",
      "name": "Notify Dashboard",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [850, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Get VIP Customers",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get VIP Customers": {
      "main": [
        [
          {
            "node": "Send VIP Discount Emails",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send VIP Discount Emails": {
      "main": [
        [
          {
            "node": "Notify Dashboard",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {}
}
