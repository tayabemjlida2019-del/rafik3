// Prisma Schema for Al-Rafiq Platform
// Database: PostgreSQL with PostGIS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  USER
  PROVIDER
  ADMIN
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ListingType {
  HOTEL
  HOME
  RESTAURANT
  TAXI
}

enum ListingStatus {
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  REJECTED
  SUSPENDED
}

enum PriceUnit {
  PER_NIGHT
  PER_MEAL
  PER_RIDE
  PER_HOUR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  EXPIRED
  ESCROW_HELD
  COMPLETED
  CANCELLED_BY_USER
  CANCELLED_BY_PROVIDER
  DISPUTED
  REFUNDED
  RESOLVED_USER
  RESOLVED_PROVIDER
  REVIEWED
}

enum PaymentMethod {
  CCP_TRANSFER
  BARIDIMOB
  CIB
  CASH
}

enum PaymentStatus {
  PENDING
  VERIFICATION_REQUIRED
  CAPTURED
  RELEASED
  REFUNDED
  FAILED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SubscriptionPlan {
  FREE
  STARTER
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum DisputeReason {
  NOT_AS_DESCRIBED
  KEY_NOT_DELIVERED
  UNCLEAN
  SAFETY_ISSUE
  OVERCHARGE
  NO_SHOW
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_USER
  RESOLVED_PROVIDER
  CLOSED
}

// ==========================================
// MODELS
// ==========================================

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  phone          String?   @unique
  passwordHash   String    @map("password_hash")
  fullName       String    @map("full_name")
  avatarUrl      String?   @map("avatar_url")
  role           Role      @default(USER)
  phoneVerified  Boolean   @default(false) @map("phone_verified")
  emailVerified  Boolean   @default(false) @map("email_verified")
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  provider       Provider?
  bookings       Booking[]
  reviews        Review[]
  disputesOpened Dispute[] @relation("DisputeOpener")
  disputesAgainst Dispute[] @relation("DisputeTarget")
  refreshTokens  RefreshToken[]
  notifications  Notification[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Provider {
  id               String    @id @default(uuid())
  userId           String    @unique @map("user_id")
  businessName     String    @map("business_name")
  businessType     ListingType @map("business_type")
  description      String?
  address          String?
  city             String
  wilaya           String

  // KYC
  nationalId       String?   @map("national_id")
  commerceRegister String?   @map("commerce_register")
  taxId            String?   @map("tax_id")
  kycStatus        KycStatus @default(PENDING) @map("kyc_status")
  kycReviewedAt    DateTime? @map("kyc_reviewed_at")
  kycReviewedBy    String?   @map("kyc_reviewed_by")

  // Financial
  ccpAccount       String?   @map("ccp_account")
  bankAccount      String?   @map("bank_account")

  // Stats (denormalized)
  avgRating        Float     @default(0) @map("avg_rating")
  totalReviews     Int       @default(0) @map("total_reviews")
  totalBookings    Int       @default(0) @map("total_bookings")

  isActive         Boolean   @default(true) @map("is_active")
  isFeatured       Boolean   @default(false) @map("is_featured")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings         Listing[]
  bookings         Booking[]
  subscriptions    Subscription[]
  reviews          Review[]

  @@index([city])
  @@index([wilaya])
  @@index([kycStatus])
  @@index([businessType])
  @@index([avgRating(sort: Desc)])
  @@map("providers")
}

model Listing {
  id              String        @id @default(uuid())
  providerId      String        @map("provider_id")
  type            ListingType
  title           String
  description     String?

  // Location
  address         String?
  city            String
  wilaya          String
  latitude        Float?
  longitude       Float?

  // Pricing
  basePrice       Float         @map("base_price")
  currency        String        @default("DZD")
  priceUnit       PriceUnit     @default(PER_NIGHT) @map("price_unit")

  // Type-specific data
  metadata        Json          @default("{}")

  // Moderation
  status          ListingStatus @default(PENDING_REVIEW)
  rejectionReason String?       @map("rejection_reason")

  // Stats (denormalized)
  avgRating       Float         @default(0) @map("avg_rating")
  totalReviews    Int           @default(0) @map("total_reviews")
  totalBookings   Int           @default(0) @map("total_bookings")

  isFeatured      Boolean       @default(false) @map("is_featured")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  provider        Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  images          ListingImage[]
  availability    Availability[]
  bookings        Booking[]
  reviews         Review[]
  categories      Category[]

  @@index([providerId])
  @@index([type])
  @@index([city])
  @@index([wilaya])
  @@index([status])
  @@index([basePrice])
  @@index([avgRating(sort: Desc)])
  @@index([type, city, status])
  @@map("listings")
}

model ListingImage {
  id            String   @id @default(uuid())
  listingId     String   @map("listing_id")
  url           String
  thumbnailUrl  String?  @map("thumbnail_url")
  altText       String?  @map("alt_text")
  sortOrder     Int      @default(0) @map("sort_order")
  isPrimary     Boolean  @default(false) @map("is_primary")
  createdAt     DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
}

model Availability {
  id            String   @id @default(uuid())
  listingId     String   @map("listing_id")
  date          DateTime @db.Date
  isAvailable   Boolean  @default(true) @map("is_available")
  priceOverride Float?   @map("price_override")
  createdAt     DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
  @@index([listingId, date])
  @@index([listingId, isAvailable, date])
  @@map("availability")
}

model Booking {
  id               String        @id @default(uuid())
  bookingRef       String        @unique @map("booking_ref")
  userId           String        @map("user_id")
  listingId        String        @map("listing_id")
  providerId       String        @map("provider_id")

  // Dates
  checkIn          DateTime?     @map("check_in")
  checkOut         DateTime?     @map("check_out")

  // Details
  guests           Int           @default(1)
  specialRequests  String?       @map("special_requests")

  // Financial
  subtotal         Float
  commissionRate   Float         @map("commission_rate")
  commission       Float
  totalAmount      Float         @map("total_amount")
  providerPayout   Float         @map("provider_payout")

  // Status
  status           BookingStatus @default(PENDING)

  // Cancellation
  cancelledAt      DateTime?     @map("cancelled_at")
  cancellationReason String?     @map("cancellation_reason")
  refundAmount     Float?        @map("refund_amount")

  // Timestamps
  confirmedAt      DateTime?     @map("confirmed_at")
  completedAt      DateTime?     @map("completed_at")
  expiresAt        DateTime?     @map("expires_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  // Relations
  user             User          @relation(fields: [userId], references: [id])
  listing          Listing       @relation(fields: [listingId], references: [id])
  provider         Provider      @relation(fields: [providerId], references: [id])
  transaction      Transaction?
  review           Review?
  dispute          Dispute?

  @@index([userId])
  @@index([listingId])
  @@index([providerId])
  @@index([status])
  @@index([bookingRef])
  @@index([checkIn, checkOut])
  @@map("bookings")
}

model Transaction {
  id              String        @id @default(uuid())
  bookingId       String        @unique @map("booking_id")

  // Payment
  amount          Float
  currency        String        @default("DZD")
  paymentMethod   PaymentMethod @map("payment_method")
  status          PaymentStatus @default(PENDING)

  // CCP specific
  receiptUrl      String?       @map("receipt_url")
  verifiedBy      String?       @map("verified_by")
  verifiedAt      DateTime?     @map("verified_at")

  // Provider Payout
  payoutAmount    Float?        @map("payout_amount")
  payoutStatus    PayoutStatus  @default(PENDING) @map("payout_status")
  payoutAt        DateTime?     @map("payout_at")
  payoutReference String?       @map("payout_reference")

  // Metadata
  gatewayRef      String?       @map("gateway_ref")
  failureReason   String?       @map("failure_reason")
  metadata        Json          @default("{}")

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status])
  @@index([payoutStatus])
  @@index([paymentMethod])
  @@index([createdAt])
  @@map("transactions")
}

model Subscription {
  id          String             @id @default(uuid())
  providerId  String             @map("provider_id")
  plan        SubscriptionPlan
  status      SubscriptionStatus @default(ACTIVE)
  price       Float

  startsAt    DateTime           @map("starts_at")
  expiresAt   DateTime           @map("expires_at")
  cancelledAt DateTime?          @map("cancelled_at")
  autoRenew   Boolean            @default(true) @map("auto_renew")

  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([status])
  @@index([expiresAt])
  @@map("subscriptions")
}

model Review {
  id             String   @id @default(uuid())
  bookingId      String   @unique @map("booking_id")
  userId         String   @map("user_id")
  listingId      String   @map("listing_id")
  providerId     String   @map("provider_id")

  rating         Int
  comment        String?

  // Specific ratings
  cleanliness    Int?
  communication  Int?
  value          Int?
  locationRating Int?     @map("location_rating")

  // Provider response
  providerReply  String?  @map("provider_reply")
  repliedAt      DateTime? @map("replied_at")

  // Moderation
  isVisible      Boolean  @default(true) @map("is_visible")
  reported       Boolean  @default(false)

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  booking  Booking  @relation(fields: [bookingId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  listing  Listing  @relation(fields: [listingId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  @@index([listingId])
  @@index([providerId])
  @@index([userId])
  @@index([rating])
  @@map("reviews")
}

model Dispute {
  id             String        @id @default(uuid())
  bookingId      String        @unique @map("booking_id")
  openedBy       String        @map("opened_by")
  against        String

  reason         DisputeReason
  description    String
  evidenceUrls   Json          @default("[]") @map("evidence_urls")

  status         DisputeStatus @default(OPEN)

  // Resolution
  resolvedBy     String?       @map("resolved_by")
  resolutionNote String?       @map("resolution_note")
  refundAmount   Float?        @map("refund_amount")

  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  booking    Booking @relation(fields: [bookingId], references: [id])
  opener     User    @relation("DisputeOpener", fields: [openedBy], references: [id])
  target     User    @relation("DisputeTarget", fields: [against], references: [id])

  @@index([bookingId])
  @@index([status])
  @@index([openedBy])
  @@map("disputes")
}

model Category {
  id        String   @id @default(uuid())
  listingId String   @map("listing_id")
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  listing   Listing    @relation(fields: [listingId], references: [id], onDelete: Cascade)
  items     MenuItem[]

  @@index([listingId])
  @@map("categories")
}

model MenuItem {
  id          String   @id @default(uuid())
  categoryId  String   @map("category_id")
  name        String
  description String?
  price       Float
  imageUrl    String?  @map("image_url")
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("menu_items")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false) @map("is_read")
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ==========================================
// AUDIT & SECURITY
// ==========================================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String   // CREATE_BOOKING, UPDATE_LISTING, LOGIN, etc.
  entityType String   @map("entity_type") // Booking, Listing, User, etc.
  entityId   String?  @map("entity_id")
  changes    Json     @default("{}")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
