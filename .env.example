# ============================================================
# RAFIQ EXECUTIVE ASSISTANT — Environment Variables
# ============================================================

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rafiq_db
POSTGRES_USER=rafiq_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# FastAPI
API_SECRET_KEY=CHANGE_ME_SECRET_KEY_256BIT
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CIB Payment Gateway
CIB_API_BASE_URL=https://api.cib.dz/v1
CIB_API_KEY=YOUR_CIB_API_KEY
CIB_SECRET_KEY=YOUR_CIB_SECRET_KEY
CIB_MERCHANT_ID=YOUR_MERCHANT_ID
CIB_WEBHOOK_SECRET=YOUR_CIB_HMAC_SECRET
CIB_CALLBACK_URL=https://your-domain.dz/webhooks/cib/payment

# n8n
N8N_HOST=n8n
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=rafiq_admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N_PASSWORD
N8N_ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY
WEBHOOK_URL=https://your-domain.dz/n8n/

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Next.js Frontend
NEXT_PUBLIC_API_URL=https://your-domain.dz/api
NEXT_PUBLIC_WS_URL=wss://your-domain.dz/ws

# CORS
ALLOWED_ORIGINS=https://your-domain.dz,http://localhost:3000

# Invoice
INVOICE_COMPANY_NAME=منصة الرفيق
INVOICE_COMPANY_ADDRESS=الجزائر العاصمة، الجزائر
INVOICE_TAX_NUMBER=YOUR_TAX_NUMBER
INVOICE_LOGO_PATH=/app/assets/rafiq_logo.png
