# ==========================================
# Al-Rafiq — Environment Variables Template
# ==========================================
# Copy this file and rename to .env.production (or .env.staging)
# NEVER commit actual secrets to version control!

# Environment
NODE_ENV=production
PORT=3001

# Database
DB_NAME=rafiq
DB_USER=rafiq_user
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD_64_CHARS
DATABASE_URL="postgresql://rafiq_user:CHANGE_ME@postgres:5432/rafiq?schema=public"

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# JWT — Use: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_USE_DIFFERENT_OPENSSL_RAND_HEX_32
JWT_REFRESH_EXPIRES_IN=7d

# CORS — Comma separated origins
CORS_ORIGINS=https://rafiq.dz,https://www.rafiq.dz

# Cloudinary (Image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Next.js Public API URL
NEXT_PUBLIC_API_URL=https://rafiq.dz/api/v1

# Platform
PLATFORM_NAME=الرفيق
PLATFORM_CCP_ACCOUNT=00799999XXXXXXXXXX
